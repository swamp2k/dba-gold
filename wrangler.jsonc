{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dba-gold",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "DBA_GOLD_DATA",
      "id": "c83bbb7fdb8a48909e65d175cdebcc94"
    }
  ],
  "triggers": {
    "crons": ["0 * * * *"]
  },
  "observability": {
    "enabled": true
  }
}
